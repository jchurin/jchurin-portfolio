{
  "name": "",
  "homepage": "https://jchurin.github.io/jchurin-portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "format": "prettier --write \"app/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,js,jsx,json,css}\"",
    "generate:favicon": "node scripts/generate-favicon.js",
    "predeploy": "npm run generate:favicon && npm run build && cp build/client/index.html build/client/404.html",
    "deploy": "gh-pages -d build/client"
  },
  "dependencies": {
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "clsx": "^2.1.1",
    "gh-pages": "^6.3.0",
    "isbot": "^5.1.31",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
